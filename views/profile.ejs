<%- include('./partials/header') %>

<% if(typeof success !== 'undefined' && success.length > 0){ %>
    <div class="absolute top-20 right-10 z-50 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 shadow-md">
        <p class="font-medium flex items-center gap-2"><i class="ri-checkbox-circle-fill text-lg"></i> <%= success %></p>
    </div>
<% } %>

<main class="flex-grow w-full max-w-4xl mx-auto px-6 md:px-20 py-12">
    <div class="bg-white rounded-3xl shadow-sm border border-zinc-200 overflow-hidden">
        <div class="h-32 bg-zinc-900 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-zinc-700 to-zinc-900 border-b border-zinc-200/50"></div>
        <div class="px-8 pb-10">
            <div class="flex flex-col md:flex-row gap-8 items-start -mt-16">
                
                <div class="flex flex-col items-center w-full md:w-1/3">
                    <% if(user.profilePic){ %>
                        <div class="w-32 h-32 rounded-full border-4 border-white overflow-hidden bg-zinc-100 shadow-md mb-4 flex items-center justify-center">
                            <img class="w-full h-full object-cover" src="data:image/jpeg;base64,<%= user.profilePic.toString('base64') %>" alt="Profile Picture" />
                        </div>
                    <% } else { %>
                        <div class="w-32 h-32 rounded-full border-4 border-white bg-zinc-100 flex items-center justify-center shadow-md mb-4">
                            <i class="ri-user-3-fill text-5xl text-zinc-300"></i>
                        </div>
                    <% } %>
                    <h2 class="text-2xl font-bold tracking-tight text-zinc-900 text-center"><%= user.fullname || 'User Profile' %></h2>
                    <p class="text-zinc-500 text-sm mb-6 bg-zinc-100 px-3 py-1 rounded-full mt-2"><%= user.email %></p>
                </div>
                
                <div class="w-full md:w-2/3 pt-6 md:pt-20">
                    <h3 class="text-xl font-bold tracking-tight text-zinc-900 mb-6 flex items-center gap-2 border-b border-zinc-100 pb-3">
                        <i class="ri-settings-4-line text-zinc-400"></i> Profile Settings
                    </h3>
                    
                    <form class="flex flex-col gap-5 w-full" autocomplete="off" action="/users/profile/update" enctype="multipart/form-data" method="post">
                        
                        <div>
                            <label for="fullname" class="block text-sm font-medium text-zinc-700 mb-1">Full Name</label>
                            <input id="fullname" name="fullname" type="text" value="<%= user.fullname %>" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all" />
                        </div>

                        <div>
                            <label for="contact" class="block text-sm font-medium text-zinc-700 mb-1">Contact Number</label>
                            <input id="contact" name="contact" type="text" value="<%= user.contact %>" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all" />
                        </div>
                        
                        <div>
                            <label for="profilePic" class="block text-sm font-medium text-zinc-700 mb-1">Update Profile Picture</label>
                            <label class="flex items-center gap-3 w-full px-4 py-3 bg-zinc-50 border border-dashed border-zinc-300 rounded-xl cursor-pointer hover:bg-zinc-100 transition-all text-sm text-zinc-600">
                                <i class="ri-image-add-line text-lg text-zinc-400"></i>
                                <span>Choose a new picture</span>
                                <input id="profilePic" name="profilePic" type="file" class="hidden" />
                            </label>
                        </div>

                        <div class="mt-4 text-right">
                            <button type="submit" class="px-8 py-3 rounded-xl font-medium text-white bg-zinc-900 hover:bg-zinc-800 transition-all shadow-md active:scale-95 inline-flex items-center gap-2">
                                <i class="ri-save-3-line"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('./partials/footer') %>
