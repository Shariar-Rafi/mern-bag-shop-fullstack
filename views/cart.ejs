<%- include('./partials/header') %>

<% if(typeof success !== 'undefined' && success.length > 0){ %>
  <div class="absolute top-20 right-10 z-50 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 shadow-md">
      <p class="font-medium flex items-center gap-2"><i class="ri-checkbox-circle-fill text-lg"></i> <%= success %></p>
  </div>
<% } %>

<main class="flex-grow w-full max-w-7xl mx-auto px-6 md:px-20 py-12">
    <h1 class="text-3xl font-bold tracking-tight mb-8">Shopping Cart</h1>

    <% if(typeof user !== 'undefined' && user.cart && user.cart.length > 0){ %>
    <div class="flex flex-col lg:flex-row gap-10 items-start">
        <!-- Cart Item Card -->
        <div class="w-full lg:w-[35%] rounded-2xl overflow-hidden border border-zinc-200 bg-white shadow-sm flex flex-col">
            <div class="relative w-full h-80 flex items-center justify-center bg-[<%= user.cart[0].bgColor %>]">
                <img class="h-[16rem] object-contain drop-shadow-xl" src="data:image/jpeg;base64,<%= user.cart[0].image.toString('base64') %>" alt="Product Image" />
            </div>
            <div class="flex-grow flex flex-col justify-between">
                <div class="px-6 py-5 bg-[<%= user.cart[0].panelColor %>] text-[<%= user.cart[0].textColor %>]">
                    <h3 class="text-sm font-medium uppercase tracking-wider mb-1 opacity-80">Product</h3>
                    <h2 class="text-2xl font-bold tracking-tight leading-tight"><%= user.cart[0].name %></h2>
                </div>
                <!-- Price Box matching text/bg for minimal UI -->
                <div class="px-6 py-4 bg-zinc-900 text-white flex items-center justify-between">
                    <span class="text-lg font-medium opacity-90">Net Total</span>
                    <span class="text-2xl font-bold">৳ <%= bill %></span>
                </div>
            </div>
        </div>

        <!-- Order Summary Detail -->
        <div class="w-full lg:w-[65%] bg-white rounded-2xl border border-zinc-200 shadow-sm p-8">
            <h3 class="text-2xl font-bold tracking-tight mb-6">Price Breakdown</h3>
            
            <div class="space-y-4 text-zinc-600 mb-8 border-b border-zinc-100 pb-8">
                <div class="flex justify-between items-center text-lg">
                    <span>Total MRP</span>
                    <span class="font-semibold text-zinc-900">৳ <%= user.cart[0].price %></span>
                </div>
                <div class="flex justify-between items-center text-lg">
                    <span>Discount on MRP</span>
                    <span class="font-semibold text-green-600">- ৳ <%= user.cart[0].discount %></span>
                </div>
                <div class="flex justify-between items-center text-lg">
                    <span>Platform Fee</span>
                    <span class="font-semibold text-zinc-900">৳ 20</span>
                </div>
                <div class="flex justify-between items-center text-lg">
                    <span>Shipping Fee</span>
                    <span class="font-semibold text-green-600 uppercase tracking-widest text-sm text-center px-3 py-1 bg-green-50 rounded-md">Free</span>
                </div>
            </div>

            <div class="flex justify-between items-center mb-8">
                <h3 class="text-xl font-bold tracking-tight text-zinc-900">Total Amount</h3>
                <h3 class="text-xl font-bold text-green-600">৳ <%= bill %></h3>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4 pt-4 border-t border-zinc-100">
                <form action="/cart/empty" method="post" class="w-full sm:w-auto">
                    <button type="submit" class="w-full sm:w-auto px-6 py-3 rounded-xl font-medium border border-red-200 text-red-600 bg-red-50 hover:bg-red-100 transition-colors flex items-center justify-center gap-2 shadow-sm cursor-pointer">
                        <i class="ri-delete-bin-line"></i> Empty
                    </button>
                </form>
                <form action="/cart/order/<%= user.cart[0]._id %>" method="post" class="w-full sm:flex-grow flex">
                    <button type="submit" class="w-full px-8 py-3 rounded-xl font-medium text-white bg-zinc-900 hover:bg-zinc-800 transition-colors flex items-center justify-center gap-2 shadow-md text-lg">
                        <i class="ri-secure-payment-line"></i> Place Order Now
                    </button>
                </form>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="w-full py-24 flex flex-col items-center justify-center text-center bg-white rounded-3xl border border-dashed border-zinc-300">
        <div class="w-24 h-24 bg-zinc-50 rounded-full flex items-center justify-center mb-6">
            <i class="ri-shopping-cart-2-line text-4xl text-zinc-300"></i>
        </div>
        <h3 class="text-2xl font-bold text-zinc-900 mb-2">Your cart is empty</h3>
        <p class="text-zinc-500 max-w-md mb-8">Looks like you haven't added anything to your cart yet. Discover some amazing products in our shop.</p>
        <a href="/shop" class="px-8 py-3 bg-zinc-900 text-white font-medium rounded-full shadow-md hover:bg-zinc-800 transition-all">Go to Shop</a>
    </div>
    <% } %>
</main>

<%- include('./partials/footer') %>
