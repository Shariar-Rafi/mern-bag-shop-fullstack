<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scatch</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="font-['helvetica_now_display']">
    <nav class="w-full px-20 py-3 flex items-center justify-between">
      <a href="/"><h3 class="text-xl italic">Scatch</h3></a>
      <div class="flex gap-8">
        <% var loggedIn = typeof loggedIn !== "undefined" ? loggedIn : true  %>

        <% if(loggedIn){ %>
          <a href="/shop">Shop</a>
          <a href="/owners/admin">Admin</a>
          <a href="/users/profile">My Profile</a>
          <a href="/users/orders">My Orders</a>
          <a href="/cart">Cart</a>
        </div>
        <div class="flex items-center gap-10">
          <p>Welcome, <span class="font-semibold text-blue-600"><%= user?.fullname %></span>.</p>
          <button class="py-2 px-4 bg-red-600 hover:bg-red-700 font-semibold text-white rounded-sm"><a href="/users/logout">Logout</a></button>
        </div>
        <% } %>
    </nav>
  </body>
</html>
