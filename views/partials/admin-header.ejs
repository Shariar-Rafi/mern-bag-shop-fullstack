<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scatch</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="font-['helvetica_now_display']">
    <nav class="w-full px-20 py-3 flex items-center justify-between">
      <a href="/"><h3 class="text-xl italic">Scatch</h3></a>
      <div class="flex gap-8">
        <% var loggedIn = typeof loggedIn !== "undefined" ? loggedIn : true  %>

        <% if(loggedIn){ %>
          <a href="/shop" class="font-semibold">Go To Shop</a>
        </div>
        <div class="flex items-center gap-10">
          <p>Welcome, <span class="font-semibold text-blue-600">Admin.</span></p>
        </div>
        <% } %>
    </nav>
  </body>
</html>
