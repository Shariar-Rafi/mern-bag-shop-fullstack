<%- include('./partials/header') %>

<main class="flex-grow flex items-center justify-center w-full max-w-7xl mx-auto px-6 md:px-20 py-10">
    <div class="max-w-md w-full">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-zinc-900 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="ri-shield-user-fill text-2xl text-white"></i>
            </div>
            <h1 class="text-3xl font-bold tracking-tight mb-2">Admin Access</h1>
            <p class="text-zinc-500">Please enter your credentials to access the admin portal.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-zinc-200">
            <form action="/create" method="post" class="space-y-4">
                <div>
                    <input class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400" type="email" placeholder="Email" name="email" required />
                </div>
                <div>
                    <input class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400" type="password" placeholder="Password" name="password" required />
                </div>
                <button type="submit" class="w-full py-3 mt-4 bg-zinc-900 hover:bg-zinc-800 text-white rounded-xl font-medium transition-colors shadow-md">
                    Login to Portal
                </button>
            </form>
        </div>
    </div>
</main>

<%- include('./partials/footer') %>
