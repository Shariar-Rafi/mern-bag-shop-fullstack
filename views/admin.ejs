<%- include('./partials/admin-header') %>

<% if(typeof success !== 'undefined' && success.length > 0){ %>
    <div class="absolute top-20 right-10 z-50 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 shadow-md">
        <p class="font-medium flex items-center gap-2"><i class="ri-checkbox-circle-fill text-lg"></i> <%= success %></p>
    </div>
<% } %>

<main class="flex-grow flex items-center justify-center w-full max-w-4xl mx-auto px-6 md:px-20 py-12">
    <div class="w-full bg-white rounded-3xl shadow-sm border border-zinc-200 overflow-hidden">
        
        <div class="px-8 py-6 border-b border-zinc-100 flex items-center gap-4 bg-zinc-50">
            <div class="w-10 h-10 bg-zinc-900 rounded-full flex items-center justify-center">
                <i class="ri-add-box-line text-white text-lg"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Create New Product</h2>
                <p class="text-sm text-zinc-500">Fill in the product details to add it to the shop.</p>
            </div>
        </div>
        
        <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data" class="p-8">
            <div class="space-y-8">
                
                <!-- Product Details -->
                <div>
                    <h3 class="text-lg font-bold tracking-tight text-zinc-800 mb-4 pb-2 border-b border-zinc-100 flex items-center gap-2">
                        <i class="ri-shopping-bag-3-fill text-zinc-400"></i> Product Information
                    </h3>
                    
                    <div class="mb-6 flex flex-col sm:flex-row items-center gap-4">
                        <label class="w-full sm:w-auto px-6 py-4 border-2 border-dashed border-zinc-300 rounded-xl cursor-pointer hover:bg-zinc-50 hover:border-zinc-400 transition-all flex items-center justify-center gap-3 text-zinc-600">
                            <i class="ri-image-add-fill text-xl text-zinc-400"></i>
                            <span class="font-medium text-sm">Upload Product Image</span>
                            <input name="image" type="file" class="hidden" required />
                        </label>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Name</label>
                            <input name="name" type="text" placeholder="Bag Title" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400" required />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Price (৳)</label>
                            <input name="price" type="number" placeholder="Original Price" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400" required />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Discount (৳)</label>
                            <input name="discount" type="number" placeholder="Discount Amount" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400" />
                        </div>
                    </div>
                </div>

                <!-- Theme Details -->
                <div>
                    <h3 class="text-lg font-bold tracking-tight text-zinc-800 mb-4 pb-2 border-b border-zinc-100 flex items-center gap-2">
                        <i class="ri-palette-fill text-zinc-400"></i> Product Theme Colors
                    </h3>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Background Color</label>
                            <input name="bgcolor" type="text" placeholder="e.g. #f3f4f6" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400 font-mono text-sm" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Panel Color</label>
                            <input name="panelcolor" type="text" placeholder="e.g. #ffffff" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400 font-mono text-sm" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Text Color</label>
                            <input name="textcolor" type="text" placeholder="e.g. #18181b" class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-zinc-900 focus:outline-none transition-all placeholder:text-zinc-400 font-mono text-sm" />
                        </div>
                    </div>
                </div>

                <div class="pt-4 flex justify-end">
                    <button type="submit" class="px-8 py-4 bg-zinc-900 text-white rounded-xl font-medium hover:bg-zinc-800 transition-all shadow-md active:scale-95 flex items-center gap-2">
                        <i class="ri-check-line text-lg"></i> Create Product
                    </button>
                </div>
            </div>
        </form>
    </div>
</main>

<%- include('./partials/footer') %>
