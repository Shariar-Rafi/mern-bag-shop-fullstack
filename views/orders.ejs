<%- include('./partials/header') %>

<main class="flex-grow w-full max-w-5xl mx-auto px-6 md:px-20 py-12">
    <div class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight mb-2">My Orders</h1>
        <p class="text-zinc-500">View and manage your ongoing order details.</p>
    </div>

    <% if(typeof user !== 'undefined' && user.order && user.order.length > 0){ %>
    <div class="bg-white rounded-3xl border border-zinc-200 shadow-sm overflow-hidden flex flex-col md:flex-row gap-8 items-stretch p-8 relative">
        <!-- Status Badge -->
        <div class="absolute top-8 right-8 px-4 py-1.5 bg-orange-50 text-orange-600 border border-orange-200 rounded-full text-sm font-semibold flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            In Progress
        </div>

        <div class="w-full md:w-1/3 flex flex-col items-center">
            <div class="w-full h-64 flex items-center justify-center rounded-2xl bg-[<%= user.order[0].bgColor %>] mb-4">
                <img class="h-48 object-contain drop-shadow-lg" src="data:image/jpeg;base64,<%= user.order[0].image.toString('base64') %>" alt="<%= user.order[0].name %>" />
            </div>
            <div class="w-full text-center px-4 py-3 bg-[<%= user.order[0].panelColor %>] rounded-xl text-[<%= user.order[0].textColor %>]">
                <h3 class="text-xl font-bold tracking-tight"><%= user.order[0].name %></h3>
            </div>
        </div>

        <div class="w-full md:w-2/3 flex flex-col justify-between pt-8 md:pt-0">
            <div>
                <h3 class="text-2xl font-bold tracking-tight text-zinc-900 mb-6 border-b border-zinc-100 pb-4">Order Summary</h3>
                <div class="space-y-4 text-zinc-600 mb-8">
                    <div class="flex justify-between items-center text-lg">
                        <span>Total MRP</span>
                        <span class="font-medium text-zinc-900">৳ <%= user.order[0].price %></span>
                    </div>
                    <div class="flex justify-between items-center text-lg">
                        <span>Discount on MRP</span>
                        <span class="font-medium text-green-600">- ৳ <%= user.order[0].discount %></span>
                    </div>
                    <div class="flex justify-between items-center text-lg">
                        <span>Platform Fee</span>
                        <span class="font-medium text-zinc-900">৳ 20</span>
                    </div>
                    <div class="flex justify-between items-center text-lg">
                        <span>Shipping Fee</span>
                        <span class="font-medium text-green-600 uppercase tracking-widest text-sm text-center px-3 py-1 bg-green-50 rounded-md">Free</span>
                    </div>
                </div>
            </div>

            <div class="bg-zinc-50 p-6 rounded-2xl border border-zinc-100 mt-auto">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold tracking-tight text-zinc-900">Total Amount</h3>
                    <h3 class="text-3xl font-bold text-green-600">৳ <%= bill %></h3>
                </div>
                <form action="/users/order/cancel" method="post" class="w-full cursor-pointer">
                    <button type="submit" class="w-full py-4 rounded-xl font-medium text-red-600 bg-red-50 hover:bg-red-100 border border-red-200 transition-colors shadow-sm flex items-center justify-center gap-2 active:scale-95">
                        <i class="ri-close-circle-fill"></i> Cancel Ongoing Order
                    </button>
                </form>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="w-full py-24 flex flex-col items-center justify-center text-center bg-white rounded-3xl border border-dashed border-zinc-300">
        <div class="w-24 h-24 bg-zinc-50 rounded-full flex items-center justify-center mb-6">
            <i class="ri-box-3-line text-4xl text-zinc-300"></i>
        </div>
        <h3 class="text-2xl font-bold text-zinc-900 mb-2">No ongoing orders</h3>
        <p class="text-zinc-500 max-w-md mb-8">You haven't placed any orders yet. Visit the shop to add some bags to your collection.</p>
        <a href="/shop" class="px-8 py-3 bg-zinc-900 text-white font-medium rounded-full shadow-md hover:bg-zinc-800 transition-all">Go to Shop</a>
    </div>
    <% } %>
</main>

<%- include('./partials/footer') %>
